{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "helpers:pinGitHubActionDigestsToSemver"
  ],
  "prHourlyLimit": 2,
  "minimumReleaseAge": "3 days",
  "labels": ["dependencies"],
  "automerge": false,
  "reviewers": ["CarlosEduJs"],
  "branchPrefix": "renovate/",
  "gitAuthor": "Renovate Bot <bot@renovateapp.com>",
  "schedule": ["before 9am on monday"],
  "packageRules": [
    {
      "description": "Group Fumadocs packages — they are versioned in lockstep",
      "matchPackageNames": ["fumadocs-core", "fumadocs-mdx", "fumadocs-ui"],
      "groupName": "Fumadocs",
      "automerge": false
    },
    {
      "description": "Group Next.js and React core",
      "matchPackageNames": ["next", "react", "react-dom"],
      "groupName": "Next.js + React",
      "automerge": false
    },
    {
      "description": "Group Tailwind ecosystem",
      "matchPackageNames": ["tailwindcss", "@tailwindcss/postcss", "tailwind-merge", "tw-animate-css"],
      "groupName": "Tailwind CSS"
    },
    {
      "description": "Group linter and formatter",
      "matchPackageNames": ["oxlint", "oxfmt"],
      "groupName": "Oxlint"
    },
    {
      "description": "Group TypeScript and type packages",
      "matchPackageNames": ["typescript", "@types/node", "@types/react", "@types/react-dom", "@types/mdx"],
      "groupName": "TypeScript"
    },
    {
      "description": "Group Mermaid diagram packages",
      "matchPackageNames": ["mermaid", "beautiful-mermaid"],
      "groupName": "Mermaid"
    },
    {
      "description": "Auto-merge patch updates for non-major deps",
      "matchUpdateTypes": ["patch"],
      "automerge": true
    },
    {
      "description": "GitHub Actions — patch and minor grouped",
      "matchManagers": ["github-actions"],
      "matchUpdateTypes": ["patch", "minor"],
      "groupName": "GitHub Actions updates",
      "labels": ["dependencies", "github-actions"],
      "automerge": true
    },
    {
      "description": "GitHub Actions — major updates",
      "matchManagers": ["github-actions"],
      "matchUpdateTypes": ["major"],
      "groupName": "GitHub Actions major updates",
      "labels": ["dependencies", "github-actions"]
    }
  ]
}
